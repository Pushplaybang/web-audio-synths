{
  "branches": [
    "main"
  ],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          {
            "breaking": true,
            "release": "major"
          },
          {
            "type": "feat",
            "release": "minor"
          },
          {
            "type": "fix",
            "release": "patch"
          },
          {
            "type": "perf",
            "release": "patch"
          }
        ],
        "parserOpts": {
          "noteKeywords": [
            "BREAKING CHANGE",
            "BREAKING CHANGES"
          ]
        }
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            {
              "type": "feat",
              "section": "✨ Features"
            },
            {
              "type": "fix",
              "section": "🐛 Bug Fixes"
            },
            {
              "type": "perf",
              "section": "⚡ Performance"
            },
            {
              "type": "refactor",
              "section": "♻️ Refactoring"
            },
            {
              "type": "docs",
              "section": "📝 Documentation"
            },
            {
              "type": "test",
              "section": "✅ Tests"
            },
            {
              "type": "ci",
              "section": "👷 CI"
            },
            {
              "type": "chore",
              "section": "🧹 Chores"
            },
            {
              "type": "build",
              "section": "📦 Build"
            }
          ]
        }
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": false,
        "failComment": false,
        "releasedLabels": [
          "released"
        ]
      }
    ]
  ]
}
